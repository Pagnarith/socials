{
  "functions": {
    "api/telegram-webhook.js": {
      "maxDuration": 25
    },
    "api/cron/*.js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-content",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/weekly-review",
      "schedule": "0 3 * * 1"
    },
    {
      "path": "/api/cron/monthly-milestone",
      "schedule": "0 3 1 * *"
    }
  ]
}
