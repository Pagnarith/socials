{
  "name": "socials-digital-financial-plan",
  "version": "1.0.0",
  "description": "Multi-platform content management hub for Minecraft & Rhino 3D creators",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "dashboard",
    "telegram-bot",
    "dataverse"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev --workspace=dashboard",
    "dev:bot": "npm run start --workspace=telegram-bot",
    "build": "npm run build --workspace=dashboard",
    "lint": "npm run lint --workspace=dashboard",
    "setup": "npm install && cp -n .env.example .env || true",
    "update:youtube": "node scripts/update-youtube-channel.js",
    "set:telegram-webhook": "node scripts/set-telegram-webhook.js"
  },
  "dependencies": {
    "googleapis": "^118.0.0",
    "dotenv": "^16.0.0"
  },
  "keywords": [
    "minecraft",
    "rhino3d",
    "youtube",
    "facebook",
    "tiktok",
    "telegram",
    "dataverse",
    "content-management"
  ],
  "author": "imphanpagnarith",
  "license": "MIT"
}
